rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── UTILS ───────────────────────────────────────────────────────────────
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        (request.auth.token.email != null && (request.auth.token.email == 'nalendraputra71@gmail.com' || request.auth.token.email == 'NalendraPutra71@gmail.com')) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin')
      ); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // RBAC Helpers
    function getMember(wsId) {
      return get(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid));
    }
    function isOwner(wsId) { 
      return isSignedIn() && exists(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid)).data.role == "owner"; 
    }
    function isEditor(wsId) { 
      return isSignedIn() && exists(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid)).data.role in ["owner", "editor"]; 
    }
    function isMember(wsId) { 
      return isSignedIn() && exists(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid)); 
    }

    // ─── DEFAULT DENY ────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── USERS ───────────────────────────────────────────────────────────────
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /global_notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && incoming().uid == userId;
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'nickname', 'avatar', 'username', 'activeUntil', 'plan', 'hasUsedPromo', 'emailVerified', 'createdAt', 'themeId', 'bio', 'following', 'followers', 'aiTokensUsed', 'aiRequestsCount', 'completedTour', 'role'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['followers'])) ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      
      match /hubaiConfig/{document=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /aiChats/{document=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // ─── DASHBOARD & TODOS ──────────────────────────────────────────────────
    match /workspaces/{wsId}/dashboard/config {
      allow read: if isMember(wsId);
      allow write: if isEditor(wsId);
    }
    match /workspaces/{wsId}/todos/{todoId} {
      allow read: if isMember(wsId);
      allow create: if isEditor(wsId) && incoming().userId == request.auth.uid;
      allow update: if isEditor(wsId) && (incoming().diff(existing()).affectedKeys().hasOnly(['completed', 'completedAt', 'text', 'dueDate', 'updatedAt', 'type']));
      allow delete: if isEditor(wsId);
    }

    // Collection Group rule for memberships
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Collection Group rule for content
    match /{path=**}/content/{contentId} {
      allow read: if isSignedIn() && (
        resource.data.isPublic == true || 
        request.auth.uid in resource.data.sharedUids
      );
    }

    // ─── ADMINS ───────────────────────────────────────────────────────────────
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin(); // Only admins can add other admins
    }

    // ─── PLANS & PROMOS ───────────────────────────────────────────────────────────
    match /plans/{planId} {
       allow read: if true;
       allow write: if isAdmin();
    }
    match /promos/{promoId} {
       allow read: if true;
       allow write: if isAdmin();
    }

    // ─── TRANSACTIONS ───────────────────────────────────────────────────────────
    match /transactions/{txId} {
       allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
       allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
       allow update, delete: if isAdmin();
    }
    match /config/system {
       allow read: if true;
       allow write: if isAdmin();
    }
    match /usernames/{username} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Validated via transaction in UserProfile
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (resource == null || resource.data.get('uid', request.auth.uid) == request.auth.uid);
    }

    match /global_notifications/{notifId} {
       allow read: if request.auth != null;
       allow write: if isAdmin();
    }
    match /tickets/{ticketId} {
       allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
       allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
       allow update: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['messages', 'updatedAt', 'status', 'readByUser'])));
       allow delete: if isAdmin();
    }

    match /accountDeletionReasons/{reasonId} {
       allow create: if isSignedIn();
       allow read, update, delete: if isAdmin();
    }

    // ─── WORKSPACES ──────────────────────────────────────────────────────────
    match /soc_posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
      allow update: if isSignedIn() && (
        (incoming().diff(existing()).affectedKeys().hasAny(['likes', 'reposts', 'pollData', 'repliesCount', 'isArchived'])) ||
        (request.auth.uid == existing().authorId && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'updatedAt']))
      );
      allow delete: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid);
    }

    match /soc_chats/{chatId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /soc_messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── WORKSPACES ──────────────────────────────────────────────────────────
    match /workspaces/{wsId} {
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || resource.data.get('publicLinkEnabled', false) == true || isAdmin());
      allow get: if isMember(wsId) || (isSignedIn() && (resource == null || resource.data.get('publicLinkEnabled', false) == true || isAdmin()));
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow delete: if isOwner(wsId) || isAdmin();
      allow update: if (isEditor(wsId) || isAdmin()) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'publicLinkEnabled', 'settings']);

      // ─── MEMBERS ───────────────────────────────────────────────────────────
      match /members/{memberId} {
        allow read: if isMember(wsId) || isAdmin();
        allow create: if isSignedIn() && (
          isOwner(wsId) || isAdmin() ||
          (request.auth.uid == memberId && incoming().role == "owner" && 
           getAfter(/databases/$(database)/documents/workspaces/$(wsId)).data.ownerId == request.auth.uid)
        );
        allow delete: if isOwner(wsId) || isAdmin() || (request.auth.uid == memberId && existing().role != "owner");
        allow update: if (isOwner(wsId) && incoming().diff(existing()).affectedKeys().hasOnly(['role'])) || (request.auth.uid == memberId && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status == "active") || isAdmin();
      }

      // ─── CONTENT ───────────────────────────────────────────────────────────
      match /content/{contentId} {
        allow read: if isMember(wsId) || isAdmin() || 
                    get(/databases/$(database)/documents/workspaces/$(wsId)).data.publicLinkEnabled == true || 
                    (resource != null && (
                      resource.data.isPublic == true || 
                      request.auth.uid in resource.data.sharedUids
                    ));
        allow create: if (isEditor(wsId) || isAdmin()) && incoming().workspaceId == wsId && (incoming().userId == request.auth.uid || isAdmin());
        allow delete: if isEditor(wsId) || isAdmin();
        allow update: if isEditor(wsId) || isAdmin() || (
          resource != null && 
          resource.data.isPublic == true && 
          resource.data.get('allowComments', false) == true && 
          incoming().diff(existing()).affectedKeys().hasOnly(['comments'])
        );
      }

      // ─── CONNECTED ACCOUNTS & INBOX ───────────────────────────────────────
      match /connectedAccounts/{accountId} {
        allow read, write: if isSignedIn();
      }

      match /inbox/{messageId} {
        allow read, write: if isSignedIn();
      }

      match /commentReplies/{commentId} {
        allow read, write: if isSignedIn();
      }

      match /todos/{todoId} {
        allow read, write: if isSignedIn();
      }

      match /dashboard/{dashboardId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}