rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── UTILS ───────────────────────────────────────────────────────────────
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        (request.auth.token.email != null && (request.auth.token.email == 'nalendraputra71@gmail.com' || request.auth.token.email == 'NalendraPutra71@gmail.com')) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin')
      ); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // RBAC Helpers
    function getMember(wsId) {
      return get(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid));
    }
    function isOwner(wsId) { 
      return isSignedIn() && exists(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid)).data.role == "owner"; 
    }
    function isEditor(wsId) { 
      return isSignedIn() && exists(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid)).data.role in ["owner", "editor"]; 
    }
    function isMember(wsId) { 
      return isSignedIn() && exists(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid)); 
    }

    // ─── DEFAULT DENY ────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── USERS ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow get: if isSignedIn();
      // Allow searching for users by email (limited to prevent scraping)
      allow list: if isSignedIn() && (
        resource.data.email == request.auth.token.email || 
        isAdmin() ||
        (request.query.limit <= 5)
      );
      allow create: if isSignedIn() && request.auth.uid == userId && incoming().uid == userId;
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'nickname', 'avatar', 'username', 'activeUntil', 'plan', 'hasUsedPromo', 'emailVerified', 'createdAt', 'themeId'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── DASHBOARD & TODOS ──────────────────────────────────────────────────
    match /workspaces/{wsId}/dashboard/config {
      allow read: if isMember(wsId);
      allow write: if isEditor(wsId);
    }
    match /workspaces/{wsId}/todos/{todoId} {
      allow read: if isMember(wsId);
      allow create: if isEditor(wsId) && incoming().userId == request.auth.uid;
      allow update: if isEditor(wsId) && (incoming().diff(existing()).affectedKeys().hasOnly(['completed', 'completedAt', 'text', 'dueDate', 'updatedAt', 'type']));
      allow delete: if isEditor(wsId);
    }

    // Collection Group rule for memberships
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── ADMINS ───────────────────────────────────────────────────────────────
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin(); // Only admins can add other admins
    }

    // ─── PLANS & PROMOS ───────────────────────────────────────────────────────────
    match /plans/{planId} {
       allow read: if true;
       allow write: if isAdmin();
    }
    match /promos/{promoId} {
       allow read: if true;
       allow write: if isAdmin();
    }

    // ─── TRANSACTIONS ───────────────────────────────────────────────────────────
    match /transactions/{txId} {
       allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
       allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
       allow update, delete: if isAdmin();
    }
    match /config/system {
       allow read: if isSignedIn();
       allow write: if isAdmin();
    }
    match /usernames/{username} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Validated via transaction in UserProfile
      allow delete: if isSignedIn() && existing().uid == request.auth.uid;
    }

    match /global_notifications/{notifId} {
       allow read: if request.auth != null;
       allow write: if isAdmin();
    }
    match /tickets/{ticketId} {
       allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
       allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
       allow update: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['messages', 'updatedAt', 'status', 'readByUser'])));
       allow delete: if isAdmin();
    }

    match /accountDeletionReasons/{reasonId} {
       allow create: if isSignedIn();
       allow read, update, delete: if isAdmin();
    }

    // ─── WORKSPACES ──────────────────────────────────────────────────────────
    match /soc_posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
      allow update: if isSignedIn() && (
        (incoming().diff(existing()).affectedKeys().hasAny(['likes', 'reposts']) && !incoming().diff(existing()).affectedKeys().hasAny(['authorId', 'authorName', 'authorAvatar', 'authorUsername', 'content', 'createdAt', 'replyTo'])) ||
        (request.auth.uid == existing().authorId && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'updatedAt']))
      );
      allow delete: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid);
    }

    match /soc_chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in incoming().participants;
      allow update: if isSignedIn() && request.auth.uid in existing().participants && incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt']);
    }

    match /soc_messages/{messageId} {
      allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/soc_chats/$(resource.data.chatId)).data.participants;
      allow create: if isSignedIn() && request.auth.uid == incoming().senderId && request.auth.uid in get(/databases/$(database)/documents/soc_chats/$(incoming().chatId)).data.participants;
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── WORKSPACES ──────────────────────────────────────────────────────────
    match /workspaces/{wsId} {
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || resource.data.get('publicLinkEnabled', false) == true);
      allow get: if isMember(wsId) || (isSignedIn() && (resource == null || resource.data.get('publicLinkEnabled', false) == true));
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow delete: if isOwner(wsId);
      allow update: if isEditor(wsId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'publicLinkEnabled', 'settings']);

      // ─── MEMBERS ───────────────────────────────────────────────────────────
      match /members/{memberId} {
        allow read: if isMember(wsId);
        allow create: if isSignedIn() && (
          isOwner(wsId) || 
          (request.auth.uid == memberId && incoming().role == "owner" && 
           getAfter(/databases/$(database)/documents/workspaces/$(wsId)).data.ownerId == request.auth.uid)
        );
        allow delete: if isOwner(wsId) || (request.auth.uid == memberId && existing().role != "owner");
        allow update: if (isOwner(wsId) && incoming().diff(existing()).affectedKeys().hasOnly(['role'])) || (request.auth.uid == memberId && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status == "active");
      }

      // ─── CONTENT ───────────────────────────────────────────────────────────
      match /content/{contentId} {
        allow read: if isMember(wsId) || get(/databases/$(database)/documents/workspaces/$(wsId)).data.publicLinkEnabled == true;
        allow create: if isEditor(wsId) && incoming().workspaceId == wsId && incoming().userId == request.auth.uid;
        allow delete: if isEditor(wsId);
        allow update: if isEditor(wsId) && (
          isOwner(wsId) ||
          (incoming().diff(existing()).affectedKeys().hasOnly([
            'status', 'metrics', 'adsMetrics', 'title', 'caption', 
            'pillar', 'platform', 'pic', 'isAds', 'uploadHour', 
            'uploadMinute', 'day', 'month', 'year', 'briefCopywriting',
            'objective', 'referenceText', 'referenceLink', 'referenceLinks', 'referenceImage', 'customFields',
            'linkAsset', 'linkUpload', 'linkSosmed', 'archived', 'updatedAt', 'metricsUpdatedAt',
            'id', 'workspaceId', 'userId'
          ]))
        );
      }
    }
  }
}
