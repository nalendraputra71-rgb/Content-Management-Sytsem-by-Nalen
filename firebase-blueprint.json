{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Extended user information stored in Firestore",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "username": { "type": "string" },
        "fullName": { "type": "string" },
        "nickname": { "type": "string" },
        "avatar": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "username"]
    },
    "Workspace": {
      "title": "Workspace",
      "description": "Collaborative container for content",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "publicLinkEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId"]
    },
    "WorkspaceMember": {
      "title": "Workspace Member",
      "description": "Mapping of users to roles within a workspace",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "editor", "viewer"] },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workspaceId", "userId", "role"]
    },
    "Content": {
      "title": "Social Media Content",
      "description": "Main CMS posting document",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "pillar": { "type": "string" },
        "platform": { "type": "string" },
        "status": { "type": "string" },
        "metrics": { "type": "object" },
        "isPublic": { "type": "boolean" },
        "allowComments": { "type": "boolean" }
      },
      "required": ["workspaceId", "userId", "title"]
    },
    "Todo": {
      "title": "Dashboard Todo",
      "description": "Manual tasks for the dashboard todos widget",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "userId": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "DashboardConfig": {
      "title": "Dashboard Configuration",
      "description": "Sticky notes, layout, and other widget states",
      "type": "object",
      "properties": {
        "stickyNote": { "type": "string" },
        "layout": { "type": "array" },
        "clockType": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "ConnectedAccount": {
      "title": "Connected Social Media Account",
      "description": "OAuth token and metadata for connected platforms (Meta, TikTok)",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "platform": { "type": "string", "enum": ["meta", "instagram", "tiktok"] },
        "accountName": { "type": "string" },
        "accountId": { "type": "string" },
        "accessToken": { "type": "string", "description": "Encrypted access token" },
        "refreshToken": { "type": "string", "description": "Encrypted refresh token" },
        "tokenExpiresAt": { "type": "string", "format": "date-time" },
        "addedByUserId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "expired", "revoked"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workspaceId", "platform", "accountId"]
    },
    "SocialMessage": {
      "title": "Unified Social Inbox Message",
      "description": "Direct messages or comments synced from Meta/TikTok API",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "platform": { "type": "string" },
        "type": { "type": "string", "enum": ["direct_message", "comment"] },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "content": { "type": "string" },
        "externalMessageId": { "type": "string" },
        "isRead": { "type": "boolean" },
        "repliedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workspaceId", "platform", "type", "content"]
    },
    "CommentReplies": {
      "title": "Comment Replies",
      "description": "Persisted comments and replies for posts in workspace",
      "type": "object",
      "properties": {
        "postComments": { "type": "array" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "/workspaces/{workspaceId}": {
      "schema": "Workspace",
      "description": "Workspaces metadata"
    },
    "/workspaces/{workspaceId}/members/{memberId}": {
      "schema": "WorkspaceMember",
      "description": "Role-based membership within a workspace"
    },
    "/workspaces/{workspaceId}/content/{contentId}": {
      "schema": "Content",
      "description": "Posts associated with a specific workspace"
    },
    "/workspaces/{workspaceId}/todos/{todoId}": {
      "schema": "Todo",
      "description": "Internal tasks for specific workspaces"
    },
    "/workspaces/{workspaceId}/dashboard/config": {
      "schema": "DashboardConfig",
      "description": "State persistence for dashboard widgets"
    },
    "/workspaces/{workspaceId}/connectedAccounts/{accountId}": {
      "schema": "ConnectedAccount",
      "description": "Encrypted OAuth tokens linking specific platforms"
    },
    "/workspaces/{workspaceId}/inbox/{messageId}": {
      "schema": "SocialMessage",
      "description": "Synced DMs and comments for the unified inbox"
    },
    "/workspaces/{workspaceId}/commentReplies/{commentId}": {
      "schema": "CommentReplies",
      "description": "Persisted custom comments and replies"
    }
  }
}
